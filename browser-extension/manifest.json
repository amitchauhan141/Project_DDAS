{
  "manifest_version": 3,
  "name": "DDAS Download Sync",
  "version": "1.0.0",
  "description": "Auto-sync completed browser downloads to DDAS dashboard.",
  "permissions": ["downloads", "storage"],
  "host_permissions": [
    "http://localhost:4000/*",
    "https://localhost:4000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "DDAS Download Sync"
  },
  "options_page": "options.html"
}
